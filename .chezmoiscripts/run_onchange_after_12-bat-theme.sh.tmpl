#!/usr/bin/env bash
# bat theme: Catppuccin Mocha
# Brewfile hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}
set -euo pipefail
eval "$(/opt/homebrew/bin/brew shellenv)"

if ! command -v bat &>/dev/null; then
    echo "bat not found, skipping theme install"
    echo "  Install bat first: brew install bat"
    echo "  Then retry: chezmoi apply"
    exit 0
fi

theme_dir="$(bat --config-dir)/themes"
mkdir -p "$theme_dir"

echo "==> Installing bat Catppuccin Mocha theme..."
if curl -fsSL -o "${theme_dir}/Catppuccin Mocha.tmTheme" \
    "https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme"; then
    bat cache --build
    echo "  Done."
else
    echo "  Warning: failed to download bat theme (network issue?)"
    echo "  Retry: chezmoi apply"
fi
