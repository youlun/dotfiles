#!/usr/bin/env bash
# Brewfile hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}
set -euo pipefail
eval "$(/opt/homebrew/bin/brew shellenv)"

echo "==> Updating Homebrew..."
brew update

echo "==> Installing Brewfile packages..."
if ! brew bundle --file="${HOME}/.config/homebrew/Brewfile" 2>&1; then
    echo ""
    echo "Warning: brew bundle had failures. Checking what's missing..."
    echo ""
    brew bundle check --file="${HOME}/.config/homebrew/Brewfile" --verbose 2>&1 | grep -v "^Resolving" || true
    echo ""
    echo "To retry: chezmoi apply --force"
    echo "  - If MAS apps failed, sign into the App Store first"
    echo "  - If a cask checksum failed, try: brew update && brew upgrade --cask <name>"
fi

{{ if .is_mbp -}}
# Create OrbStack SSH config placeholder so Include doesn't warn before first launch
if [ ! -f ~/.orbstack/ssh/config ]; then
    mkdir -p ~/.orbstack/ssh
    touch ~/.orbstack/ssh/config
fi
{{ end -}}
